# OcuSmart / synergy-glasses-backend — environment template
# Copy to `.env` if your host or tooling loads it (e.g. docker-compose, Railway).
#
# The FastAPI app does not read this file by default. Set these in your process
# environment, or add python-dotenv in main.py if you want auto-load from `.env`.

# -----------------------------------------------------------------------------
# Used by Docker image CMD (and many PaaS hosts)
# -----------------------------------------------------------------------------
# Uvicorn listen port (default 8000 if unset).
PORT=8000

# -----------------------------------------------------------------------------
# Documented for operators — not read by Python code unless you wire them in
# -----------------------------------------------------------------------------
# TFLite model file (default in code: ./models/model.tflite next to the app).
# MODEL_PATH=models/model.tflite

# CORS allowed origins, comma-separated, or * (main.py currently allows all;
# wire os.environ.get("CORS_ORIGINS") into CORSMiddleware to use this).
# CORS_ORIGINS=https://your-app.example,http://localhost:3000

# -----------------------------------------------------------------------------
# Laptop gate (read by laptop_scene.py when models/objects_model.tflite exists)
# -----------------------------------------------------------------------------
# If UNSET or * or empty: any predicted class counts as laptop if confidence passes
# (fits Kaggle c0..cN folders that are all laptop variants).
# Set a comma-separated list to allow only those indices, e.g. only true "laptop" vs negatives:
# LAPTOP_CLASS_IDS=3,7
# LAPTOP_CLASS_IDS=*

# Minimum softmax confidence for top-1 laptop decision. Default 0.4 (range 0.35–0.45).
# LAPTOP_CONFIDENCE_MIN=0.4

# -----------------------------------------------------------------------------
# Bbox distance calibration (laptop gate path): distance_cm = D_ref * sqrt(ref_ratio / current_ratio)
# current_ratio = bbox area as % of frame (same units as ref). Tune with real captures.
# DISTANCE_D_REF=60.0
# DISTANCE_REF_RATIO_PCT=25.0
# DISTANCE_MIN_RATIO_PCT=0.5
# DISTANCE_CM_MIN=20.0
# DISTANCE_CM_MAX=150.0

# -----------------------------------------------------------------------------
# Roboflow Inference workflow (optional laptop gate; requires inference-sdk, Python <3.13)
# -----------------------------------------------------------------------------
# When objects_model.tflite is present, Roboflow is NOT called per request (TFLite is primary).
# Roboflow is used only if the workflow gate is on and the objects model file is missing.
# LAPTOP_USE_ROBOFLOW_WORKFLOW=1
# ROBOFLOW_API_KEY=
# Default matches InferenceHTTPClient(api_url="https://detect.roboflow.com", ...).
# ROBOFLOW_API_URL=https://detect.roboflow.com
# ROBOFLOW_WORKSPACE=<your_workspace_slug>
# ROBOFLOW_WORKFLOW_ID=<your_workflow_id>
# ROBOFLOW_WORKFLOW_IMAGE_KEY=image
# Optional: only if your workflow expects a "classes" parameter (many laptop workflows do not).
# ROBOFLOW_WORKFLOW_CLASSES=Chair, Laptop, Desk
# Optional JSON for arbitrary workflow parameters: ROBOFLOW_WORKFLOW_PARAMETERS_JSON={"classes":"Chair, Laptop, Desk"}
# ROBOFLOW_LAPTOP_LABELS=laptop
# ROBOFLOW_WORKFLOW_USE_CACHE=true
